{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/chatbot.umd.js", "destination": "/dist/chatbot.umd.js" },
    { "source": "/chatbot.es.js", "destination": "/dist/chatbot.es.js" },
    { "source": "/chatbot.css", "destination": "/dist/chatbot.css" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        }
      ]
    }
  ]
} 